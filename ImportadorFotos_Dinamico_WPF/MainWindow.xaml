<Window x:Class="ImportadorFotos_Dinamico_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Importador Dinámico de Fotos v3.0 (C# / .NET 9.0)" 
        Height="550" Width="900"
        MinHeight="500" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        SourceInitialized="Window_SourceInitialized">
    <!-- 
        xmlns="http://microsoft.com"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://microsoft.com"
        xmlns:mc="http://openxmlformats.org"
    -->

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- 0. Cabecera y Selección Global de Perfiles -->
            <RowDefinition Height="Auto"/>
            <!-- 1. Configuración del Perfil Seleccionado -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Destino Común y Opciones -->
            <RowDefinition Height="Auto"/>
            <!-- 3. Visualización de Ficheros (Listbox / ListViews) -->
            <RowDefinition Height="*"/>
            <!-- 4. Pie de Ventana / Estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- =================================================================== -->
        <!-- ROW 0: GESTIÓN DE PERFILES DINÁMICOS                                -->
        <!-- =================================================================== -->
        <GroupBox Header=" Perfil de Cámara o Tarjeta de Origen " Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="10">
                <Label Content="Dispositivo Activo:" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbPerfiles" Width="250" Margin="10,0" 
                          DisplayMemberPath="Id" 
                          SelectionChanged="CmbPerfiles_SelectionChanged"/>

                <Button x:Name="BtnNuevoPerfil" Content="➕ Añadir Perfil" Width="110" Margin="5,0" Click="BtnNuevoPerfil_Click"/>
                <Button x:Name="BtnEliminarPerfil" Content="❌ Eliminar" Width="90" Margin="5,0" Click="BtnEliminarPerfil_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- =================================================================== -->
        <!-- ROW 1: CONFIGURACIÓN ESPECÍFICA DEL PERFIL SELECCIONADO            -->
        <!-- =================================================================== -->
        <GroupBox Header=" Parámetros del Perfil " Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Directorio Origen del Perfil -->
                <Label Content="Ruta de Origen:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtDirOrigen" Grid.Row="0" Grid.Column="1" Height="24" VerticalAlignment="Center" Margin="5" KeyDown="TxtDirOrigen_KeyDown"/>
                <Button x:Name="BtnSelOrigen" Content="..." Grid.Row="0" Grid.Column="2" Width="30" Height="24" Margin="5,5,15,5" Click="BtnSelDir_Click"/>

                <!-- Plantilla y Sesión del Perfil -->
                <Label Content="Plantilla Carpeta:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtPlantilla" Grid.Row="0" Grid.Column="4" Height="24" VerticalAlignment="Center" Margin="5" LostFocus="TxtPerfilControl_LostFocus"/>

                <CheckBox x:Name="ChkUsarSesion" Content="Añadir texto fijo de sesión a este origen" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Click="TxtPerfilControl_LostFocus"/>
            </Grid>
        </GroupBox>

        <!-- =================================================================== -->
        <!-- ROW 2: DESTINO COMÚN Y OPCIONES GLOBALES                           -->
        <!-- =================================================================== -->
        <GroupBox Header=" Configuración de Destino y Filtros " Grid.Row="2" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Ruta de Destino:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtDirDestino" Grid.Row="0" Grid.Column="1" Height="24" VerticalAlignment="Center" Margin="5"/>
                <Button x:Name="BtnSelDestino" Content="..." Grid.Row="0" Grid.Column="2" Width="30" Height="24" Margin="5,5,15,5" Click="BtnSelDir_Click"/>

                <Label Content="Fecha desde:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"/>
                <DatePicker x:Name="DpFechaFiltro" Grid.Row="0" Grid.Column="4" Height="24" VerticalAlignment="Center" Margin="5"/>

                <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Margin="5,5,5,0">
                    <CheckBox x:Name="ChkReemplazar" Content="Reemplazar ficheros existentes" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkUsarDateTaken" Content="Usar fecha EXIF (Date Taken)" Margin="0,0,20,0" Checked="ChkUsarDateTaken_CheckedChanged" Unchecked="ChkUsarDateTaken_CheckedChanged" VerticalAlignment="Center"/>
                    <Label Content="Texto Sesión:" Margin="0,0,5,0" Padding="0,3,0,0" VerticalAlignment="Top"/>
                    <TextBox x:Name="TxtTextoSesionGlobal" Width="120" Height="22" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Margin="5,0,5,0">
                    <Label Content="Los ficheros RAW/DNG se copiarán en carpeta diferente." 
                           Background="LightYellow"
                           Margin="0,0,5,0" Padding="3"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- =================================================================== -->
        <!-- ROW 3: VISTA DE FICHEROS Y ACCIONES PRINCIPALES                     -->
        <!-- =================================================================== -->
        <Grid Grid.Row="3" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Ficheros en el origen actual -->
            <GroupBox Header=" Ficheros Encontrados en Origen Activo ">
                <ListView x:Name="LvFicheros">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Nombre del Archivo" Width="280" DisplayMemberBinding="{Binding Nombre}"/>
                            <GridViewColumn x:Name="ColFecha" Header="Date Taken" Width="180" DisplayMemberBinding="{Binding Fecha, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <!-- Panel Central de Botones de Acción -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="BtnLeer" Content="🔍 Leer" Height="35" Width="80" Margin="0,0,0,15" Click="BtnLeer_Click"/>
                <Button x:Name="BtnCopiar" Content="🚀 Copiar" Height="35" Width="80" Click="BtnCopiar_Click"/>
            </StackPanel>

            <!-- Directorios creados en destino -->
            <GroupBox Header=" Carpetas Destino " Grid.Column="2">
                <ListView x:Name="LvDirectorios">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Ruta Completa Creada" Width="240" DisplayMemberBinding="{Binding Nombre}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>
        </Grid>

        <!-- =================================================================== -->
        <!-- ROW 4: PIE DE VENTANA (ESTADO Y CRÉDITOS)                          -->
        <!-- =================================================================== -->
        <StatusBar Grid.Row="4" Background="LightYellow" Padding="0,3,0,0">
            <StatusBarItem HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch">
                <Label x:Name="LabelInfo" Content="Inicializando aplicación..." 
                       Foreground="#555555" Padding="3"/>
            </StatusBarItem>
            
            <StatusBarItem HorizontalAlignment="Right" MinWidth="280" HorizontalContentAlignment="Stretch">
                <Label x:Name="LabelCopyR" Content="copyright" 
                       Foreground="#555555" Padding="3"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

    